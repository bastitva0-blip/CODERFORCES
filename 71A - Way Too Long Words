#71A - Way Too Long Words
# CONCEPTS 1) TAKE A INPUT 2)FOR LOOP 3)IF-ELSE CONDITION BLOCK 

n = int(input())

for _ in range(n):
    word = input()

    if len(word) <= 10:
        print(word)
    else:
        print(word[0] + str(len(word)-2) + word[-1])
